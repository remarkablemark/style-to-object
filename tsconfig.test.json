{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "allowJs": true,
    "types": ["jest", "node"]
  },
  "include": [
    "eslint.config.mts",
    "jest.config.ts",
    "tsdown.config.ts",
    "src",
    "__tests__"
  ],
  "exclude": ["node_modules"]
}
